{
  "rewrites": [
    {
      "source": "/n8n_course/:chapter",
      "destination": "/n8n_course/:chapter.html"
    },
    {
      "source": "/ebook/:slug",
      "destination": "/E-Books/:slug.html"
    },
    {
      "source": "/posts/:slug",
      "destination": "/posts/:slug.html"
    },
    {
      "source": "/Web3",
      "destination": "/Web3/index.html"
    }
  ]
}
